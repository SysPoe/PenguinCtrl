{
  "audio": {
    "upload": {
      "maxMb": 300
    },
    "masterVolume": {
      "defaultDb": 0,
      "minDb": -40,
      "maxDb": 6
    }
  },
  "realtime": {
    "instanceBroadcastMs": 100,
    "reconnectDelayMs": 2000
  },
  "ui": {
    "script": {
      "minZoom": 50,
      "maxZoom": 200,
      "zoomStep": 10,
      "wheelZoomStep": 5
    },
    "cues": {
      "defaultManualFadeOutSeconds": 2
    }
  },
  "system": {
    "notes": "When running with pulseaudio please ensure you are running it through pw-jack"
  },
  "osc": {
    "target": {
      "ip": "127.0.0.1",
      "oscPort": 8000,
      "remotePort": 6553
    }
  }
}
