{
  "audio": {
    "upload": {
      "maxMb": 300
    },
    "buffer": {
      "sampleRate": 22050,
      "channels": 1,
      "maxCached": 8
    },
    "masterVolume": {
      "defaultDb": 0,
      "minDb": -40,
      "maxDb": 6
    }
  },
  "realtime": {
    "instanceBroadcastMs": 200,
    "reconnectDelayMs": 2000
  },
  "ui": {
    "script": {
      "minZoom": 50,
      "maxZoom": 200,
      "zoomStep": 10,
      "wheelZoomStep": 5
    },
    "cues": {
      "defaultManualFadeOutSeconds": 2
    }
  },
  "system": {
    "notes": "When running with pulseaudio please ensure you are running it through pw-jack"
  },
  "osc": {
    "targets": [
      {"ip": "192.168.200.1", "oscPort": 8000, "remotePort": 6553}
    ]
  }
}
